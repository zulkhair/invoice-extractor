# === Python (python/) ===
__pycache__/
*.py[cod]
python/.venv/
*.egg-info/
.pytest_cache/

# === Go (go/) ===
# compiled binaries (we don't commit them)
/go/server
/go/bench
/go/visioncheck
/go/ie-server
*.exe
# Go workspace files
go.work
go.work.sum

# === Env / secrets ===
.env
**/.env

# === Real invoices + ground truth are private — never commit ===
