# --- Ollama ---
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT_S=180

# --- Models (VERIFIED 2026-06-21; see ../README.md "Model tags") ---
# Bench candidate pool (all Q4, all vision-capable):
MODEL_PRIMARY=frob/nuextract-2.0:8b-q4_K_M
MODEL_SMALL=qwen2.5vl:3b-q4_K_M
MODEL_FALLBACK=qwen2.5vl:7b-q4_K_M
MODEL_TEXT=nuextract              # text-only NuExtract 1.x — bench candidate only
# BENCH_MODELS=qwen2.5vl:3b-q4_K_M,frob/nuextract-2.0:8b-q4_K_M,qwen2.5vl:7b-q4_K_M

# Live pipeline models:
TEXT_PATH_MODEL=qwen2.5vl:3b-q4_K_M
VISION_PATH_MODEL=qwen2.5vl:7b-q4_K_M

# --- Optional: two-model OCR pipeline ---
# Empty OCR_MODEL = single-VLM vision path above. Set it to OCR the image to text with a
# dedicated model, then map that text to the schema with TEXT_PATH_MODEL. Example:
#   OCR_MODEL=glm-ocr
#   TEXT_PATH_MODEL=qwen2.5:14b-instruct
# Both stay resident only with server-side OLLAMA_MAX_LOADED_MODELS=2 + enough VRAM.
OCR_MODEL=
OCR_NUM_PREDICT=2048              # cap OCR output tokens (repetition guard)

# --- Ollama runtime options ---
OLLAMA_NUM_CTX=8192               # context window (room for image + prompt + JSON)
# OLLAMA_NUM_GPU=99               # force full-GPU offload (omit = let Ollama decide)
# OLLAMA_KEEP_ALIVE=-1            # keep model resident; -1 forever, 30m, ... (server env also works)

# --- Pipeline tuning ---
TEXT_LAYER_MIN_CHARS=100
RASTER_DPI=200
RASTER_MAX_PX=1600
LLM_TEMPERATURE=0
DEFAULT_CURRENCY=                 # ISO code when none printed (e.g. IDR); empty = leave null

# --- PDF backend ---
PDF_BACKEND=poppler               # poppler shell-out (pdftotext/pdftoppm). go-fitz not built here.

# --- Paths / server ---
FIXTURES_DIR=testdata/fixtures
LABELS_DIR=testdata/labels
PORT=8000
