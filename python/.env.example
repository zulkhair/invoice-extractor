# --- Ollama ---
# Runs Ollama locally. Plain HTTP so a future Go rewrite is trivial.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_TIMEOUT_S=180          # vision calls can be slow on modest GPUs; give them room

# --- Models (VERIFIED against the Ollama registry on 2026-06-21) ---
# All Q4, sized for modest VRAM. See README "Model tags" for the
# substitution rationale ("NuExtract3 4B" does not exist).
#
# Candidate pool for the benchmark (scripts/bench.py) — the decision tool:
MODEL_PRIMARY=frob/nuextract-2.0:8b-q4_K_M       # 6.0 GB, vision (NuExtract 2.0)
MODEL_SMALL=qwen2.5vl:3b-q4_K_M                  # 3.2 GB, vision (the "4B target")
MODEL_FALLBACK=qwen2.5vl:7b-q4_K_M               # 6.0 GB, vision (messy scans)
# Text-only NuExtract 1.x — bench candidate only, NOT used by the live pipeline
# (no vision projector -> fails the vision check by design):
MODEL_TEXT=nuextract                             # ~2.2 GB, text-only

# Models the LIVE /extract pipeline calls:
TEXT_PATH_MODEL=qwen2.5vl:3b-q4_K_M              # fast path for digital PDFs
VISION_PATH_MODEL=qwen2.5vl:7b-q4_K_M            # vision path + fallback (must be vision)

# --- Pipeline tuning ---
TEXT_LAYER_MIN_CHARS=100      # per-page char threshold to call a PDF "has text layer"
RASTER_DPI=200                # render DPI for the vision path
RASTER_MAX_PX=1600            # clamp longest image edge to fit context / VRAM
LLM_TEMPERATURE=0             # deterministic extraction

# --- Paths ---
FIXTURES_DIR=tests/fixtures
LABELS_DIR=tests/labels
